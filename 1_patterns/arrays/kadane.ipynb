   "source": [
    "- For maximum subarray problems"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "827026cc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Template\n",
    "\n",
    "def kadane(nums):\n",
    "    curr = nums[0]\n",
    "    max_sum = nums[0]\n",
    "    \n",
    "    for i in range(1, len(nums)):\n",
    "        curr = max(nums[i], curr + nums[i])\n",
    "        max_sum = max(max_sum, curr)\n",
    "    \n",
    "    return max_sum"
   ]
  }
 ],
