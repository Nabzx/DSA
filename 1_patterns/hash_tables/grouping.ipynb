   "source": [
    "# Group Anagrams\n",
    "\n",
    "from collections import defaultdict\n",
    "\n",
    "def groupAnagrams(strs):\n",
    "    groups = defaultdict(list)\n",
    "    \n",
    "    for s in strs:\n",
    "        key = tuple(sorted(s))\n",
    "        groups[key].append(s)\n",
    "    \n",
    "    return list(groups.values())"
   ]
  }
 ],
